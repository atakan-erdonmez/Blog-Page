---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			.hero-image-container {
				width: min(1380px, calc(100% - 2em));
				margin: 0 auto;
				height: 40vh;
				position: sticky;
				top: 0;
				overflow: hidden;
				z-index: 0;
				border-radius: 12px;
			}
			.hero-image {
				width: 100%;
				height: 100%;
				object-fit: cover;
				filter: brightness(0.7);
				display: block;
			}
			.content-wrapper {
				position: relative;
				/* Lowered z-index to prevent overlap with zoom */
				z-index: 1;
				background-color: var(--bg-color);
				margin-top: -5vh;
				padding-top: 0;
			}

			.reveal-spacer {
				height: 10vh;
				background: linear-gradient(
					to bottom,
					transparent 0%,
					var(--bg-color) 100%
				);
				pointer-events: none;
			}
			.post-layout {
				--bg-color: #ffffff;
				background-color: var(--bg-color);
				padding-top: 2rem;
				width: min(100%, 1380px);
				max-width: calc(100% - 2em);
				margin: 0 auto;
				display: grid;
				grid-template-columns: minmax(0, 1fr) 240px;
				gap: 3rem;
				align-items: start;
				box-sizing: border-box;
			}

			/* Adjust existing main/prose styles to fit new structure */
			main {
				width: 100%;
				max-width: none;
				margin: 0;
				padding: 0;
			}
			/* Fix medium-zoom z-index issues */
			:global(.medium-zoom-overlay) {
				z-index: 1000 !important;
			}
			:global(.medium-zoom-image--opened) {
				z-index: 1001 !important;
			}

			.prose {
				width: 100%;
				max-width: 100%;
				min-width: 0;
				margin: 0;
				padding: 1em;
				box-sizing: border-box;
				color: rgb(var(--gray-dark));
			}
			/* Ensure header is on top */
			header {
				position: sticky;
				top: 0;
				z-index: 100;
			}

			.toc {
				position: sticky;
				top: 1rem;
				height: calc(100vh - 1rem);
				max-height: calc(100vh - 1rem);
				overflow: auto;
				padding: 0.75rem 0.3rem 0.75rem 0.9rem;
				justify-self: end;
				width: 240px;
				box-sizing: border-box;
			}
			.toc-title {
				margin: 0 0 0.8rem;
				font-size: 0.9rem;
				font-weight: 700;
				color: rgb(var(--gray-dark));
			}
			.toc-list {
				list-style: none;
				margin: 0;
				padding: 0;
				display: grid;
				gap: 0.25rem;
			}
			:global(.toc-list a),
			:global(.toc-list a:visited) {	
				display: block;
				text-decoration: none !important;
				color: rgb(var(--gray-dark)) !important;
				font-size: 0.92rem;
				line-height: 1.4;
				padding: 0.2rem 0;
				transition: color 0.15s ease;
			}
			.toc-list li {
				margin: 0;
			}
			.toc-sublist {
				list-style: none;
				margin: 0.35rem 0 0.15rem;
				padding-left: 0.9rem;
				display: grid;
				gap: 0.3rem;
			}
			:global(.toc-list li.toc-h3 a),
			:global(.toc-list li.toc-h3 a:visited) {
				font-size: 0.85rem;
				color: rgb(var(--gray-dark)) !important;
			}
			:global(.toc-list a.active),
			:global(.toc-list a.active:visited) {
				color: rgb(var(--gray-dark)) !important;
				font-weight: 600 !important;
			}
			:global(.toc-list a:hover) {
				color: rgb(var(--gray-dark));
			}
			.toc-empty {
				margin: 0;
				font-size: 0.88rem;
				color: rgb(var(--gray));
			}
			.title {
				margin-bottom: 1em;
				padding: 1em 0;
				text-align: left;
				line-height: 1;
			}
			.title h1 {
				margin: 0 0 0.5em 0;
			}
			.date {
				margin-bottom: 0.5em;
				color: rgb(var(--gray));
			}
			.last-updated-on {
				font-style: italic;
			}

			/* Adjustments for mobile */
			@media (max-width: 1000px) {
				.hero-image-container {
					width: calc(100% - 2em);
					height: 30vh;
					padding-left: 1.25rem;
					padding-right: 1.25rem;
					box-sizing: border-box;
				}
				.reveal-spacer {
					height: 10vh;
				}
				.content-wrapper {
					margin-top: 0;
					padding-top: 0;
				}
				.post-layout {
					grid-template-columns: 1fr;
				}
				.toc {
					position: static;
					order: -1;
					height: auto;
					max-height: none;
					padding: 0;
					width: 100%;
				}
				.post-layout,
				.prose,
				.toc {
					min-width: 0;
				}
			}
		</style>
	</head>

	<body>
		<Header />
		{heroImage && (
			<div class="hero-image-container">
				<img 
					src={typeof heroImage === 'string' ? heroImage : heroImage.src} 
					alt={title} 
					class="hero-image" 
				/>
			</div>
		)}
		<main class="content-wrapper">
			<div class="reveal-spacer"></div>
			<div class="post-layout">
				<article class="prose">
					<div class="title">
						<h1>{title}</h1>
						<div class="date">
							<FormattedDate date={pubDate} />
							{
								updatedDate && (
									<div class="last-updated-on">
										Last updated on <FormattedDate date={updatedDate} />
									</div>
								)
							}
						</div>
						<hr />
					</div>
					<slot />
				</article>
				<aside class="toc" aria-label="Table of contents">
					<h2 class="toc-title">Table of Contents</h2>
					<ul id="toc-list" class="toc-list"></ul>
					<p id="toc-empty" class="toc-empty">No sections yet.</p>
				</aside>
			</div>
		</main>


		<script>
			import mediumZoom from 'medium-zoom';

			// We initialize the zoom on images inside the article
			// The selector '.prose img' usually works for the default Astro blog, 
			// but 'article img' is safer based on your file name.
			mediumZoom('article img', {
				margin: 24,
				background: 'rgba(0,0,0,0.9)', // Darker background for contrast
			});
    	</script>

		
		<Footer />
		<script>
			/*
			  By removing 'is:inline', Astro will now bundle, minify, and optimize 
			  this script. This improves performance because the browser can 
			  cache the script file after the first load.
			*/
			const slugify = (text: string) =>
				text
					.toLowerCase()
					.trim()
					.replace(/[^\w\s-]/g, '')
					.replace(/\s+/g, '-');

			const prose = document.querySelector('.prose');
			const tocList = document.getElementById('toc-list');
			const emptyState = document.getElementById('toc-empty');
			const tocLinks: HTMLAnchorElement[] = [];

			if (prose && tocList && emptyState) {
				const headings = Array.from(prose.querySelectorAll('h2, h3')) as HTMLElement[];
				let currentH2Item: HTMLLIElement | null = null;

				headings.forEach((heading) => {
					// Ensure every heading has an ID for the TOC to link to
					if (!heading.id) {
						heading.id = slugify(heading.textContent || '');
					}

					const item = document.createElement('li');
					const tagName = heading.tagName.toLowerCase();
					item.className = `toc-${tagName}`;

					const link = document.createElement('a');
					link.href = `#${heading.id}`;
					link.textContent = heading.textContent || '';
					link.dataset.targetId = heading.id;
					tocLinks.push(link);

					item.appendChild(link);

					if (tagName === 'h2') {
						tocList.appendChild(item);
						currentH2Item = item;
					} else if (tagName === 'h3' && currentH2Item) {
						let sublist = currentH2Item.querySelector('.toc-sublist');
						if (!sublist) {
							sublist = document.createElement('ul');
							sublist.className = 'toc-sublist';
							currentH2Item.appendChild(sublist);
						}
						sublist.appendChild(item);
					} else {
						tocList.appendChild(item);
					}
				});

				// Toggle visibility of TOC based on whether headings were found
				const hasItems = tocList.children.length > 0;
				emptyState.hidden = hasItems;
				tocList.hidden = !hasItems;

				const setActiveLink = (id: string) => {
					tocLinks.forEach((tocLink) => {
						tocLink.classList.toggle('active', tocLink.dataset.targetId === id);
					});
				};

				tocLinks.forEach((tocLink) => {
					tocLink.addEventListener('click', () => {
						if (tocLink.dataset.targetId) {
							setActiveLink(tocLink.dataset.targetId);
						}
					});
				});

				const headingById = new Map(
					headings.map((heading) => [heading.id, heading])
				);

				// Using IntersectionObserver is best practice for 'ScrollSpy' functionality
				const observer = new IntersectionObserver(
					(entries) => {
						const visible = entries
							.filter((entry) => entry.isIntersecting)
							.sort(
								(a, b) =>
									a.target.getBoundingClientRect().top -
									b.target.getBoundingClientRect().top
							);

						if (visible.length > 0) {
							setActiveLink(visible[0].target.id);
							return;
						}

						const passed = headings
							.filter((heading) => heading.getBoundingClientRect().top < 140)
							.at(-1);
						if (passed) setActiveLink(passed.id);
					},
					{ rootMargin: '-18% 0px -72% 0px', threshold: [0, 1] }
				);

				headings.forEach((heading) => observer.observe(heading));

				// Handle initial load with hash or default to first heading
				const hashId = window.location.hash.replace('#', '');
				if (hashId && headingById.has(hashId)) {
					setActiveLink(hashId);
				} else if (headings.length > 0) {
					setActiveLink(headings[0].id);
				}
			}
		</script>







	</body>
</html>
