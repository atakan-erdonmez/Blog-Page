---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';
import { getCollection } from 'astro:content';

const latestPosts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 6);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main class="container">
      <section class="hero">
        <h1>Latest Posts</h1>
        <p>Notes on infrastructure, cloud, automation, and self-hosted systems.</p>
      </section>

      <section class="posts-row">
        {latestPosts.map((post) => (
          <a class="post-card" href={`/blog/${post.id}/`}>
            {post.data.heroImage ? (
              <img
                class="post-image"
                src={post.data.heroImage.src}
                alt={post.data.title}
              />
            ) : (
              <div class="post-image placeholder"></div>
            )}

            <div class="post-content">
              <p class="meta">
                <FormattedDate date={post.data.pubDate} />
              </p>
              <h2>{post.data.title}</h2>
              <p>{post.data.description}</p>
            </div>
          </a>
        ))}
      </section>
    </main>
    <Footer />
  </body>
</html>

<style>
  .container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 2rem 1.25rem 4rem;
  }

  .hero {
    margin-bottom: 2rem;
  }

  .hero h1 {
    margin-bottom: 0.5rem;
  }

  .posts-row {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.25rem;
  }

  .post-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    background: white;
    border: 1px solid rgba(var(--gray), 0.2);
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 8px 24px rgba(var(--black), 0.05);
    min-height: 360px;
    transition: transform 0.18s ease, box-shadow 0.18s ease;
  }

  .post-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 14px 30px rgba(var(--black), 0.08);
  }

  .post-image {
    width: 100%;
    height: 180px;
    object-fit: cover;
    display: block;
  }

  .placeholder {
    background: #ececec;
  }

  .post-content {
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .meta {
    margin: 0;
    font-size: 0.85rem;
    color: rgb(var(--gray));
  }

  .post-content h2 {
    margin: 0;
    font-size: 1.1rem;
    line-height: 1.3;
  }

  .post-content p:last-child {
    margin: 0;
    color: rgb(var(--gray-dark));
    line-height: 1.5;
  }

  @media (max-width: 1000px) {
    .posts-row {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .posts-row {
      grid-template-columns: 1fr;
    }
  }
</style>
