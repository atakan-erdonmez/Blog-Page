---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import githubLogo from '../assets/github_logo.png';
import linkedinLogo from '../assets/linkedin logo.png';
import blogLogo from '../assets/blog logo.png';
import kbLogo from '../assets/kb logo.png';
import projectPortfolio from '../assets/project_portfolio.png';
import internalWiki from '../assets/internal_wiki.png';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main class="landing">
      <section class="hero">
        <div class="hero-text">
          <p class="eyebrow">Infrastructure • Cloud • Automation</p>
          <h1>Atakan Erdonmez</h1>
          <p class="hero-lead">
            I design and document secure, practical infrastructure with a focus on
            automation, reproducibility, and maintainable operations.
          </p>
          <p>
            This site is the central entry point for my blog, knowledge base,
            portfolio, and other work. Most of what I build sits around self-hosted
            systems, ingress design, infrastructure as code, and operational clarity.
          </p>
        </div>
      </section>

      <section class="links-section">
        <div class="uniform-links">
          <a
            class="uniform-link social-hover"
            href="https://linkedin.com/in/atakanerdonmez"
            target="_blank"
            rel="noopener"
            aria-label="LinkedIn"
            data-hover-text="Professional experience, certifications, and career updates."
          >
            <img class="brand-logo" src={linkedinLogo.src} alt="LinkedIn" />
          </a>

          <a
            class="uniform-link social-hover"
            href="https://github.com/atakan-erdonmez"
            target="_blank"
            rel="noopener"
            aria-label="GitHub"
            data-hover-text="Infrastructure as code, automation workflows, and real-world implementations."
          >
            <img class="brand-logo" src={githubLogo.src} alt="GitHub" />
          </a>

          <a
            class="uniform-link social-hover"
            href="/blog"
            data-hover-text="Write-ups on infrastructure decisions and implementations"
          >
            <img class="brand-logo" src={blogLogo.src} alt="Blog" />
          </a>

          <a class="uniform-link social-hover" href="#" data-hover-text="Coming soon...">
            <img class="brand-logo" src={kbLogo.src} alt="Knowledge Base" />
          </a>

          <a class="uniform-link social-hover" href="#" data-hover-text="Coming soon...">
            <img class="brand-logo" src={projectPortfolio.src} alt="Project Portfolio" />
          </a>

          <a class="uniform-link social-hover" href="#" data-hover-text="Coming soon...">
            <img class="brand-logo" src={internalWiki.src} alt="Internal Wiki" />
          </a>
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>

<style>
  :root {
    --landing-bg: #0f1115;
    --card-bg: #ffffff;
    --card-border: #d7dde8;
    --text-main: #f3f4f6;
    --text-soft: #b8bec9;
    --text-muted: #8e97a7;
  }

  body {
    background: var(--landing-bg);
    color: var(--text-main);
  }

  .landing {
    max-width: 1500px;
    margin: 0 auto;
    padding: 4.5rem 1.5rem 4rem;
  }

  .hero {
    margin-bottom: 3.5rem;
  }

  .hero-text {
    max-width: 820px;
  }

  .eyebrow {
    margin: 0 0 1rem;
    font-size: 0.82rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--text-muted);
  }

  .hero h1 {
    margin: 0 0 1.1rem;
    font-size: clamp(2.8rem, 7vw, 5.4rem);
    line-height: 0.98;
    letter-spacing: -0.04em;
    color: var(--text-main);
    max-width: 10ch;
  }

  .hero-lead {
    margin: 0 0 1rem;
    max-width: 38ch;
    font-size: clamp(1.15rem, 2vw, 1.4rem);
    line-height: 1.5;
    color: var(--text-main);
    font-weight: 500;
  }

  .hero p {
    max-width: 62ch;
    margin: 0;
    font-size: 1.02rem;
    line-height: 1.8;
    color: var(--text-soft);
  }

  .links-section {
    margin-top: 0.5rem;
  }

  .uniform-links {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1rem;
    max-width: 100%;
    margin-left: auto;
    margin-right: auto;
  }

  .uniform-link {
    text-decoration: none;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #fff;
    border: 1px solid var(--card-border);
    border-radius: 14px;
    padding: 0.8rem 1rem;
    transition: transform 0.15s ease, border-color 0.15s ease;
  }

  .social-hover {
    position: relative;
    overflow: hidden;
  }

  .social-hover::before {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.75);
    opacity: 0;
    transition: opacity 0.2s ease;
    z-index: 1;
  }

  .social-hover::after {
    content: attr(data-hover-text);
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    width: calc(100% - 1.5rem);
    text-align: center;
    color: #fff;
    font-size: 0.9rem;
    line-height: 1.35;
    font-weight: 600;
    opacity: 0;
    transition: opacity 0.2s ease;
    z-index: 2;
    pointer-events: none;
  }

  .brand-logo {
    display: block;
    width: 170px;
    height: 74px;
    object-fit: contain;
  }

  .uniform-link:hover {
    transform: translateY(-2px);
    border-color: #b8c3d8;
  }

  .social-hover:hover::before,
  .social-hover:hover::after {
    opacity: 1;
  }

  @media (max-width: 900px) {
    .landing {
      padding-top: 3.5rem;
    }

    .hero {
      text-align: center;
      margin-bottom: 3rem;
    }

    .hero-text {
      margin: 0 auto;
    }

    .hero h1,
    .hero-lead,
    .hero p {
      max-width: none;
    }

    .uniform-links {
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      max-width: 100%;
    }
  }

  @media (max-width: 768px) {
    .uniform-links {
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    }
  }

  @media (max-width: 480px) {
    .uniform-links {
      grid-template-columns: repeat(1, minmax(0, 1fr));
    }
  }
</style>