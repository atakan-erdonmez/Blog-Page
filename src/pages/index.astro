---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import githubLogo from '../assets/github_logo.png';
import linkedinLogo from '../assets/linkedin logo.png';
import blogLogo from '../assets/blog logo.png';
import kbLogo from '../assets/kb logo.png';
import projectPortfolio from '../assets/project_portfolio.png';
import internalWiki from '../assets/internal_wiki.png';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main class="landing">
      <section class="hero">
        <div class="hero-text">
          <p class="eyebrow">Infrastructure • Cloud • Automation</p>
          <h1>Atakan Erdonmez</h1>
          <p>
            I build and document infrastructure, automation workflows, and self-hosted systems.
            This site is the central entry point for my blog, knowledge base, portfolio, and other projects.
          </p>
          <p>
            My focus is on practical engineering: clear architecture, reproducible deployments,
            and systems that are actually maintainable.
          </p>
        </div>

        <div class="hero-photo">
          <div class="photo-placeholder"></div>
        </div>
      </section>

      <section class="links-section">
        <div class="uniform-links">
          <a
            class="uniform-link social-hover"
            href="https://linkedin.com/in/atakanerdonmez"
            target="_blank"
            rel="noopener"
            aria-label="LinkedIn"
            data-hover-text="Take a look at my linkedin profile"
          >
            <img class="brand-logo" src={linkedinLogo.src} alt="LinkedIn" />
          </a>
          <a
            class="uniform-link social-hover"
            href="https://github.com/atakan-erdonmez"
            target="_blank"
            rel="noopener"
            aria-label="GitHub"
            data-hover-text="my projects & repos"
          >
            <img class="brand-logo" src={githubLogo.src} alt="GitHub" />
          </a>
          <a class="uniform-link social-hover" href="/blog" data-hover-text="Coming soon...">
            <img class="brand-logo" src={blogLogo.src} alt="Blog" />
          </a>
          <a class="uniform-link social-hover" href="#" data-hover-text="Coming soon...">
            <img class="brand-logo" src={kbLogo.src} alt="Knowledge Base" />
          </a>
          <a class="uniform-link social-hover" href="#" data-hover-text="Coming soon...">
            <img class="brand-logo" src={projectPortfolio.src} alt="Project Portfolio" />
          </a>
          <a class="uniform-link social-hover" href="#" data-hover-text="Coming soon...">
            <img class="brand-logo" src={internalWiki.src} alt="Internal Wiki" />
          </a>
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>

<style>
  :root {
    --landing-bg: #0f1115;
    --card-bg: #ffffff;
    --card-border: #d7dde8;
    --text-main: #f3f4f6;
    --text-soft: #b8bec9;
  }

  body {
    background: var(--landing-bg);
    color: var(--text-main);
  }

  .landing {
    max-width: 1500px;
    margin: 0 auto;
    padding: 3rem 1.5rem 4rem;
  }

  .hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 3rem;
    margin-bottom: 3rem;
  }

  .eyebrow {
    margin: 0 0 0.75rem;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-soft);
    text-align: center;
  }

  .hero h1 {
    margin: 0 0 1rem;
    font-size: clamp(2.3rem, 5vw, 4.5rem);
    line-height: 1.05;
    color: var(--text-main);
  }

  .hero p {
    max-width: 62ch;
    margin: 0 0 1rem;
    font-size: 1.05rem;
    line-height: 1.75;
    color: var(--text-soft);
  }

  .hero-photo {
    display: none; /* Hide the photo section */
  }

  .hero-text {
    text-align: center;
  }

  .hero p {
    max-width: 70ch;
    margin-left: auto;
    margin-right: auto;
  }

  .links-section {
    margin-top: 0.5rem;
  }

  .uniform-links {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1rem;
    max-width: 700px; /* Adjusted for longer cards */
    margin-left: auto;
    margin-right: auto;
  }

  .uniform-link {
    text-decoration: none;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #fff;
    border: 1px solid var(--card-border);
    border-radius: 14px;
    padding: 0.8rem 1rem;
    transition: transform 0.15s ease, border-color 0.15s ease;
  }

  .social-hover {
    position: relative;
    overflow: hidden;
  }

  .social-hover::before {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.75);
    opacity: 0;
    transition: opacity 0.2s ease;
    z-index: 1;
  }

  .social-hover::after {
    content: attr(data-hover-text);
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    width: calc(100% - 1.5rem);
    text-align: center;
    color: #fff;
    font-size: 0.9rem;
    line-height: 1.35;
    font-weight: 600;
    opacity: 0;
    transition: opacity 0.2s ease;
    z-index: 2;
    pointer-events: none;
  }

  .brand-logo {
    display: block;
    width: 170px;
    height: 74px;
    object-fit: contain;
  }

  .uniform-link:hover {
    transform: translateY(-2px);
    border-color: #b8c3d8;
  }

  .social-hover:hover::before,
  .social-hover:hover::after {
    opacity: 1;
  }

  @media (max-width: 900px) {
    .hero {
      grid-template-columns: 1fr;
    }

    .links-section {
      margin-top: 0;
    }

    .uniform-links {
      grid-template-columns: repeat(2, minmax(0, 1fr)); /* 2 columns on smaller screens */
      max-width: 100%;
    }
  }

  @media (max-width: 768px) {
    /* Adjust for medium screens to maintain 2 columns */
    .uniform-links {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 480px) {
    /* Adjust for extra small screens to 1 column */
    .uniform-links {
      grid-template-columns: repeat(1, minmax(0, 1fr));
    }
  }
</style>